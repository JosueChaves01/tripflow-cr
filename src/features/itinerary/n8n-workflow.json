    "Search Restaurants": {
      "ai_tool": [
        [ { "node": "TripFlow AI Agent", "type": "ai_tool", "index": 0 } ]
      ]
    },
    "Save Itinerary": {
      "ai_tool": [
        [ { "node": "TripFlow AI Agent", "type": "ai_tool", "index": 0 } ]
      ]
    },
    "TripFlow AI Agent": {
      "main": [
