{
  "name": "TripFlow CR - AI Travel Itinerary Agent",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 400],
      "parameters": {
        "httpMethod": "POST",
        "path": "tripflow-itinerary-agent",
        "responseMode": "lastNode",
        "options": {}
      },
      "webhookId": "tripflow-itinerary-agent"
    },
    {
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 400],
      "parameters": {
        "jsCode": "const body = $input.item.json;\nconst user_id = body.user_id;\nconst messages = body.messages;\nconst preferences = body.preferences || null;\n\nif (!user_id || typeof user_id !== 'string') throw new Error('Missing user_id');\nif (!messages || !Array.isArray(messages)) throw new Error('Missing messages');\n\nconst lastMessage = messages[messages.length - 1]?.content || '';\n\nreturn { json: { user_id, messages, lastMessage, preferences, timestamp: new Date().toISOString() } };"
      }
    },
    {
      "id": "postgres-memory",
      "name": "Postgres Chat Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryPostgresChat",
      "typeVersion": 1.1,
      "position": [600, 550],
      "parameters": {
        "tableName": "n8n_chat_histories",
        "sessionId": "={{ $json.user_id }}"
      },
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Supabase Database"
        }
      }
    },
    {
      "id": "anthropic-model",
      "name": "Anthropic Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1,
      "position": [600, 700],
      "parameters": {
        "model": "claude-3-5-sonnet-20240620",
        "maxTokens": 1024
      },
      "credentials": {
        "anthropicApi": {
          "id": "YOUR_ANTHROPIC_CREDENTIAL_ID",
          "name": "Anthropic API"
        }
      }
    },
    {
