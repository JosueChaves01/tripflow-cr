    {
      "id": "tool-save",
      "name": "Save Itinerary",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [1250, 600],
      "parameters": {
        "name": "save_itinerary",
        "description": "Saves the final itinerary to the database once the user confirms. Requires user_id, preferences, days (JSON array), and total_cost.",
        "toolDescription": "Saves the final itinerary to the database once the user confirms. Requires user_id, preferences, days (JSON array), and total_cost.",
        "url": "https://ccospiksyvpryxkexhxs.supabase.co/rest/v1/itineraries",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "user_id", "value": "={{ $('Validate Input').item.json.user_id }}" },
            { "name": "status", "value": "confirmed" },
            { "name": "preferences", "value": "={{ $parameter.preferences }}" },
            { "name": "days", "value": "={{ $parameter.days }}" },
            { "name": "total_cost", "value": "={{ $parameter.total_cost }}" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNjb3NwaWtzeXZwcnl4a2V4aHhzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTA2Mjc2NywiZXhwIjoyMDk0NjM4NzY3fQ.u6SxR3py1Tdm8epN1-LvTj2P-AWT30qQQqCvHiJC3Jc"
            },
            {
              "name": "Authorization",
              "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNjb3NwaWtzeXZwcnl4a2V4aHhzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTA2Mjc2NywiZXhwIjoyMDk0NjM4NzY3fQ.u6SxR3py1Tdm8epN1-LvTj2P-AWT30qQQqCvHiJC3Jc"
            }
          ]
        }
      }
    },
    {
      "id": "llm-agent",
      "name": "TripFlow AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.4,
      "position": [600, 400],
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.lastMessage }}",
        "options": {
          "systemMessage": "=You are the TripFlow Costa Rica Travel Expert. Your goal is to design a personalized travel itinerary for the user.\n\nPre-chat User Preferences:\n- Destination: {{ $('Validate Input').item.json.preferences?.destination || 'Not specified' }}\n- Duration: {{ $('Validate Input').item.json.preferences?.duration || 'Not specified' }} days\n- Travelers: {{ $('Validate Input').item.json.preferences?.travelers || 'Not specified' }} people\n- Vibe/Style: {{ $('Validate Input').item.json.preferences?.vibe || 'Not specified' }}\n- Budget: {{ $('Validate Input').item.json.preferences?.budget || 'Not specified' }}\n- Services Needed: {{ $('Validate Input').item.json.preferences?.services?.join(', ') || 'Not specified' }}\n\nINSTRUCTIONS:\n1. If pre-chat preferences above are specified (not 'Not specified'), DO NOT ask the user for those details again! Confirm them briefly in your greeting and immediately start searching for hotels, activities, or restaurants in that destination (based on what services they asked for) using the search tools. Skip the discovery phase for those fields.\n2. If preferences are NOT specified, ask the user about their trip (dates, group size, budget, destination, etc.) in a conversational way.\n3. **Search**: Use the search_hotels, search_activities, and search_restaurants tools to find real options from the database. NEVER invent names.\n4. **Recommend**: Show 2-3 real options based on tool results.\n5. **Finalize**: When they approve, use the save_itinerary tool.\n\nIMPORTANT:\n- After saving, say EXACTLY: \"Your itinerary has been saved! You can view it now.\"\n- Your final response MUST include {\"action\": \"itinerary_saved\"} in your text when itinerary is saved."
        }
      }
    },
    {
      "id": "parse-response",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [950, 400],
      "parameters": {
        "jsCode": "const agentOutput = $input.item.json;\nlet responseText = agentOutput.output || agentOutput.text || JSON.stringify(agentOutput);\nlet action = 'chat';\n\nif (responseText.toLowerCase().includes('itinerary has been saved') || responseText.toLowerCase().includes('itinerario ha sido guardado')) {\n  action = 'itinerary_saved';\n}\n\nreturn { json: { response: responseText, action, user_id: $('Validate Input').item.json.user_id } };"
      }
    },
    {
      "id": "respond-webhook",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1200, 400],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}"
      }
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [ { "node": "Validate Input", "type": "main", "index": 0 } ]
      ]
    },
    "Validate Input": {
      "main": [
        [ { "node": "TripFlow AI Agent", "type": "main", "index": 0 } ]
      ]
    },
    "Anthropic Chat Model": {
      "ai_languageModel": [
